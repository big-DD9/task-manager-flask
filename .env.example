# Copy this file to .env and fill in real values. Never commit .env itself.

FLASK_ENV=development

# App secrets - generate real random values for anything beyond local dev
# e.g. python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me
JWT_SECRET_KEY=dev-jwt-secret-change-me

# Local dev defaults to SQLite if DATABASE_URL is unset.
# For Postgres (local docker-compose or RDS):
# DATABASE_URL=postgresql://taskuser:taskpass@localhost:5432/taskmanager
DATABASE_URL=

LOG_LEVEL=INFO
